{
  "name": "nodra",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Self-hosted cloud-architecture & diagram editor (ReactFlow + Tauri). AWS/GCP/Azure icon packs, ER diagrams, containers, PNG/SVG export.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 5173 --strictPort",
    "typecheck": "tsc --noEmit",
    "build:plugin": "node scripts/build-plugin.mjs",
    "plugins:install": "node scripts/dev-install.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@iconify/react": "^5.0.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xyflow/react": "^12.11.1",
    "html-to-image": "^1.11.13",
    "i18next": "^26.3.1",
    "nanoid": "^5.1.15",
    "react": "^19",
    "react-dom": "^19",
    "react-i18next": "^17.0.8",
    "yjs": "^13.6.31",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.0",
    "svgo": "^3.3.2",
    "typescript": "^5.6.3",
    "vite": "^8"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
